generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql" url = env("DATABASE_URL") }

model ContactSubmission {
  id        String   @id @default(cuid())
  nom       String
  email     String
  telephone String?
  vehicule  String?
  carburant String?
  miseEnCirculation String?
  message   String
  createdAt DateTime @default(now())
}