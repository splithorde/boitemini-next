generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ContactSubmission {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  carModel    String?
  fuelType    String? 
  regDate     String? 
  message     String
  createdAt   DateTime @default(now())
}