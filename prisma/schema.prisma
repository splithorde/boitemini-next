generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql" url = env("DATABASE_URL") }

model ContactSubmission {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  vehicle   String?
  fuelType  String
  regDate   String?
  message   String
  createdAt DateTime @default(now())
}