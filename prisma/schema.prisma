generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContactSubmission {
  id              String   @id @default(cuid())
  customerName    String
  customerEmail   String
  customerPhone   String?
  vehicleBrand    String?
  fuelType        String?
  registrationDate DateTime?
  message         String
  createdAt       DateTime @default(now())
}